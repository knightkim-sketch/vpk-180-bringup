          <mxGeometry x="270" y="175" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- FTDI FT4232HL -->
        <mxCell id="ftdi_a" value="FT4232HL (U20)&#xa;USB-JTAG/UART Bridge&#xa;&#xa;Port A: JTAG TDI/TDO/TCK/TMS&#xa;Port B: JTAG (chained)&#xa;Port C/D: UART (MIO42/43)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="130" width="260" height="120" as="geometry" />
        </mxCell>

        <!-- J37 Jumper (MUX) -->
