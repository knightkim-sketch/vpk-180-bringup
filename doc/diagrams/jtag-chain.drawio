        </mxCell>

        <!-- Host PC -->
        <mxCell id="pc_a" value="🖥️ Host PC&#xa;Vivado 2025.2&#xa;hw_server&#xa;&#xa;Linux: /dev/ttyUSB0 (JTAG)&#xa;       /dev/ttyUSB1 (UART)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="200" height="120" as="geometry" />
