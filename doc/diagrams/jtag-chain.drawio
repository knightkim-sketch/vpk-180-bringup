        </mxCell>

        <!-- JTAG Chain: XCZU4EG -->
        <mxCell id="zu4eg" value="XCZU4EG&#xa;System Controller&#xa;(JTAG Chain #1)&#xa;&#xa;TAP ID: 0x147B81093" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
